# Heimdall Community — Docker Compose environment
# Copy to .env (cp .env.example .env) and fill in before `docker compose up -d`.
# docker-compose.yml will refuse to start if DB_PASSWORD, DB_ROOT_PASSWORD or JWT_SECRET are empty.

# Strong, unique passwords for the MySQL container
DB_PASSWORD=
DB_ROOT_PASSWORD=

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Optional overrides
# APP_PORT=3005
# CORS_ORIGIN=http://localhost:3005
